{
  // 完整示例（JSONC 风格）：包含所有可配置字段。
  // 注意：该文件带注释，不能直接作为 --config 输入。
  // 请复制为 .json 并删除注释后使用。

  "agent": {
    // 默认 agent 启动命令
    "command": "codex --yolo",
    // 启动后等待多少秒再发送 prompt
    "startup_wait_sec": 2.0,
    // 默认工作目录（可被任务级 workdir 覆盖）
    "default_workdir": "/abs/path/to/repo",
    // 全局环境变量（可被任务级 env 覆盖）
    "env": {
      "GLOBAL_FLAG": "1"
    }
  },

  "runtime": {
    // 最大并发任务数（>=1）
    "parallelism": 3,
    // 调度轮询间隔（秒，>0）
    "poll_interval_sec": 1.0,

    // tmux session 基础名
    "tmux_session": "agent-graph",
    // multi_session: 每任务独立 session（默认）
    // single_group: 单 session 多窗口（兼容旧行为）
    "tmux_mode": "multi_session",
    // 是否保留退出后的 pane
    // true: 便于排障，可能看到 dead pane
    // false: pane 退出后不保留（runner 会自动加短暂退出缓冲，降低采集竞态）
    "remain_on_exit": true,

    // done marker 前缀
    "done_prefix": "AGENT_DONE:",
    // 任务完成时要求 agent 执行的命令模板
    // 支持变量：{marker} / {marker_shell}
    "done_command_template": "python3 scripts/report_done.py --marker {marker_shell}",

    // 全任务成功后是否自动清理 tmux session
    "cleanup_session_on_success": true,
    // capture-pane 回看行数（>=200）
    "capture_lines": 3000
  },

  "web": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8765
  },

  "tasks": [
    {
      // 任务唯一 ID（必填）
      "id": "prepare",
      // 静态 prompt
      "prompt": "准备整体升级方案。"
    },
    {
      "id": "upgrade-module-1",
      // 依赖任务 ID 列表
      "deps": ["prepare"],
      "prompt": "升级模块 1 并给出影响分析。",
      // 覆盖全局 agent.command
      "agent_command": "codex --yolo",
      // 覆盖全局 default_workdir
      "workdir": "/abs/path/to/repo/module1",
      // 任务级环境变量，覆盖同名全局变量
      "env": {
        "TASK_FLAG": "module1"
      }
    },
    {
      "id": "upgrade-module-2",
      "deps": ["prepare"],
      // prompt 可与 prompt_command 组合
      "prompt": "升级模块 2，并引用动态输入：\n{command_output}",
      // 动态命令，读取 stdout
      "prompt_command": "printf '最新依赖版本：v2.3.4\\n重点回归：登录与支付'"
    },
    {
      "id": "finalize",
      "deps": ["upgrade-module-1", "upgrade-module-2"],
      "prompt": "汇总结果并确认全部任务完成。"
    }
  ]
}
