{
  "agent": {
    "command": "codex --yolo",
    "startup_wait_sec": 2.0
  },
  "runtime": {
    "parallelism": 3,
    "poll_interval_sec": 2.0,
    "tmux_session": "agent-graph-codex"
  },
  "web": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8765
  },
  "tasks": [
    {
      "id": "prepare",
      "prompt": "先完成需求梳理和改造计划，明确模块拆分。"
    },
    {
      "id": "module-1",
      "deps": ["prepare"],
      "prompt": "负责模块 1 的升级与自测。"
    },
    {
      "id": "module-2",
      "deps": ["prepare"],
      "prompt": "负责模块 2 的升级与自测。"
    },
    {
      "id": "integration",
      "deps": ["module-1", "module-2"],
      "prompt": "整合所有改动，执行回归检查，最后给出总结。"
    }
  ]
}
